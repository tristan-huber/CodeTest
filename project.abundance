          "ioValue": 2
        },
        {
          "name": "offset",
          "ioValue": 67
        }
      ],
      "interpreterVersion": 1,
      "code": "\nfunction run(shape: Assembly, count: number = 1, offset: number = 5) {\n  console.log(\"shape in code atom\")\n\n  if (count == 0) {\n    return []\n  }\n  const isReversed = count < 0;\n  if (isReversed) {\n    offset = -1 * offset\n  }\n  count = Math.abs(count)\n\n  const result = [shape]\n  for (let i = 1; i < count; i++) {\n\n    const temp = new Assembly(shape).onLeafs((leaf) => {\n      if (leaf.is2D()) {\n        leaf.geometry = leaf.geometry.translate(offset * i, 0)\n      } else if (leaf.geometry instanceof replicad._3DShape) {\n        leaf.geometry = leaf.geometry.translate(offset * i, 0, 0)\n      }\n      return leaf;\n    })\n\n    if (temp) {\n      result.push(temp)\n    }\n    console.warn(\"foo\")\n  }\n\n  return result;\n}\n\n\n",
      "compiledCode": "\"use strict\";\nfunction run(shape, count = 1, offset = 5) {\n    console.log(\"shape in code atom\");\n    if (count == 0) {\n        return [];\n    }\n    const isReversed = count < 0;\n    if (isReversed) {\n        offset = -1 * offset;\n    }\n    count = Math.abs(count);\n    const result = [shape];\n    for (let i = 1; i < count; i++) {\n        const temp = new Assembly(shape).onLeafs((leaf) => {\n            if (leaf.is2D()) {\n                leaf.geometry = leaf.geometry.translate(offset * i, 0);\n            }\n            else if (leaf.geometry instanceof replicad._3DShape) {\n                leaf.geometry = leaf.geometry.translate(offset * i, 0, 0);\n            }\n            return leaf;\n        });\n        if (temp) {\n            result.push(temp);\n        }\n        console.warn(\"foo\");\n    }\n    return result;\n}\n"
    },
    {
      "atomType": "Code",
      "x": 0.7021484375,
      "y": 0.8430311231393776,
      "uniqueID": "id-138",
      "ioValues": [
        {
          "name": "basisPart",
          "ioValue": "__GEOMETRY_INPUT__"
        },
        {
          "name": "fillet",
          "ioValue": 1
        },
        {
          "name": "filterShapes",
          "ioValue": "__GEOMETRY_INPUT__"
        }
      ],
      "interpreterVersion": 1,
      "code": "// Fillet vertical edges in the input part. Optionally provide a selector volume\n// which filters the edges that are filleted.\n\n\nfunction run(basisPart: Assembly, fillet: number = 1, filterShapes: Assembly|undefined = undefined) {\n  console.log(basisPart)\n  const radius = fillet\n  if (!basisPart) {\n    throw new Error(\"Missing required shape input\")\n  }\n\n  if (basisPart.is2D()) {\n    throw new Error(\"2d shapes not supported right now\")\n  }\n\n  if (radius == 0) {\n    return basisPart;\n  }\n\n  if (radius < 0) {\n    throw new Error(\"Fillet radius must be 0 or positive\")\n  }\n\n  let filters: any[] = []\n  if (filterShapes instanceof Assembly) {\n    filterShapes.onLeafs((leaf) => {\n      const bounds = leaf.geometry.boundingBox.bounds;\n      filters.push(\n        (finder: replicad.Finder) => {\n          return finder.inBox(\n            bounds[0],\n            bounds[1]\n          )}\n      );\n\n      return leaf;\n    })\n  }\n\n  basisPart.onLeafs((leaf) => {\n    if (leaf.geometry instanceof replicad.Solid || leaf.geometry instanceof replicad.Compound) {\n      if (filters.length > 0) {\n        leaf.geometry = leaf.geometry.fillet({\n          radius: radius,\n          keep: true,\n          filter: new replicad.EdgeFinder().either(filters)\n        });\n      } else {\n        leaf.geometry = leaf.geometry.fillet(radius)\n      }\n    }\n    \n    return leaf;\n  })\n\n  console.log(\"blah\")\n\n  return basisPart;\n}\n\n\n",
      "compiledCode": "\"use strict\";\n// Fillet vertical edges in the input part. Optionally provide a selector volume\n// which filters the edges that are filleted.\nfunction run(basisPart, fillet = 1, filterShapes = undefined) {\n    console.log(basisPart);\n    const radius = fillet;\n    if (!basisPart) {\n        throw new Error(\"Missing required shape input\");\n    }\n    if (basisPart.is2D()) {\n        throw new Error(\"2d shapes not supported right now\");\n    }\n    if (radius == 0) {\n        return basisPart;\n    }\n    if (radius < 0) {\n        throw new Error(\"Fillet radius must be 0 or positive\");\n    }\n    let filters = [];\n    if (filterShapes instanceof Assembly) {\n        filterShapes.onLeafs((leaf) => {\n            const bounds = leaf.geometry.boundingBox.bounds;\n            filters.push((finder) => {\n                return finder.inBox(bounds[0], bounds[1]);\n            });\n            return leaf;\n        });\n    }\n    basisPart.onLeafs((leaf) => {\n        if (leaf.geometry instanceof replicad.Solid || leaf.geometry instanceof replicad.Compound) {\n            if (filters.length > 0) {\n                leaf.geometry = leaf.geometry.fillet({\n                    radius: radius,\n                    keep: true,\n                    filter: new replicad.EdgeFinder().either(filters)\n                });\n            }\n            else {\n                leaf.geometry = leaf.geometry.fillet(radius);\n            }\n        }\n        return leaf;\n    });\n    console.log(\"blah\");\n    return basisPart;\n}\n"
    },
